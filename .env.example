# Set this to your final Vercel/custom-domain URL after your first deployment.
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Optional: enables Ask Moh's AI against a local Ollama install while developing.
# The public Vercel deployment deliberately falls back to verified profile notes unless
# you configure a trusted remote model endpoint with OLLAMA_BASE_URL.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
